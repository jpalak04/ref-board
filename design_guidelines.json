  "components_guide": {
    "card": {
      "style": {
        "backgroundColor": "#1A1A1A",
        "borderRadius": 16,
        "borderWidth": 1,
        "borderColor": "rgba(255, 255, 255, 0.08)",
        "padding": 16
      },
      "behavior": "No shadow by default. On Press: Scale 0.98 + Border color slightly lighter."
    },
    "button": {
      "primary": {
        "backgroundColor": "#B5CC6A",
        "borderRadius": 9999,
        "paddingVertical": 12,
        "paddingHorizontal": 24,
        "shadowColor": "#B5CC6A",
        "shadowOpacity": 0.2,
        "shadowRadius": 10
      },
      "secondary": {
        "backgroundColor": "rgba(255,255,255,0.05)",
        "borderWidth": 1,
        "borderColor": "rgba(255,255,255,0.1)",
        "borderRadius": 9999
      }
    },
    "input": {
      "style": {
        "backgroundColor": "#0A0A0A",
        "borderWidth": 1,
        "borderColor": "rgba(255,255,255,0.1)",
        "borderRadius": 12,
        "color": "#FFFFFF",
        "padding": 16,
        "fontSize": 16
      }
    },
    "navigation": {
      "tab_bar": {
        "backgroundColor": "rgba(26, 26, 26, 0.9)",
        "blurEffect": "dark",
        "borderTopWidth": 0,
        "elevation": 0,
        "height": 60
      }
    }
  },
