  "instructions_to_main_agent": [
    "Verify if 'nativewind' is installed. If NOT, use `StyleSheet.create` with the values provided in `layout_specs` and `colors`.",
    "Do NOT use HTML elements (`div`, `span`, `img`). Use `View`, `Text`, `Image`, `Pressable`, `ScrollView`, `FlatList`.",
    "For the 'Masonry/Bento' layout: Use a 2-column layout on mobile, 3-4 on desktop. Use `FlexWrap` or a dedicated masonry component.",
    "Implement a 'Quick Save' Modal using `Modal` or `BottomSheet`.",
    "Use 'Syne' font (load via `expo-font`). If loading fails, fallback to System Sans.",
    "For the 'Team' section, use the `avatars` images provided.",
    "Ensure the background is always #141414 (Dark Mode).",
    "Add `data-testid` to all interactive elements for testing."
  ],
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": [
    "Don't make generic centered layouts. Use asymmetry.",
    "Use 2-3x more spacing than feels comfortable.",
    "Dark colors look good when used independently without gradients.",
    "Add micro-animations to every interaction (Pressable states).",
    "Avoid using AI emoji characters."
  ]
}