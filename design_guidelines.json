{
  "project_context": {
    "framework": "Expo (React Native + Web)",
    "styling_strategy": "StyleSheet or NativeWind (Tailwind is listed in prompt but missing in package.json - verify before use)",
    "component_strategy": "Custom components mimicking Shadcn/UI (Standard Shadcn is DOM-based, not RN-compatible). Use View/Text/Pressable primitives.",
    "theme": "Dark Mode Only (#141414)"
  },
  "typography": {
    "fonts": {
      "heading": {
        "family": "Syne, sans-serif",
        "description": "Art-gallery vibe, wide and confident. Use for H1-H3.",
        "fallback": "System Sans-Serif (iOS: San Francisco, Android: Roboto)",
        "google_font_url": "https://fonts.googleapis.com/css2?family=Syne:wght@400..800&display=swap"
      },
      "body": {
        "family": "Manrope, sans-serif",
        "description": "Clean, geometric, highly legible. Use for all UI text.",
        "fallback": "System Sans-Serif",
        "google_font_url": "https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap"
      },
      "mono": {
        "family": "JetBrains Mono, monospace",
        "description": "Use for metadata, dates, and tags."
      }
    },
    "scale": {
      "h1": { "size": 36, "weight": "700", "lineHeight": 40, "letterSpacing": -0.5 },
      "h2": { "size": 28, "weight": "700", "lineHeight": 32, "letterSpacing": -0.5 },
      "h3": { "size": 24, "weight": "600", "lineHeight": 28, "letterSpacing": 0 },
      "body_lg": { "size": 18, "weight": "400", "lineHeight": 26 },
      "body": { "size": 16, "weight": "400", "lineHeight": 24 },
      "caption": { "size": 12, "weight": "500", "lineHeight": 16, "letterSpacing": 1.0, "textTransform": "uppercase" }
    }
  },
  "colors": {
    "background": {
      "default": "#141414",
      "surface": "#1A1A1A",
      "surface_highlight": "#222222",
      "overlay": "rgba(20, 20, 20, 0.9)"
    },
    "brand": {
      "lime": "#B5CC6A",
      "coral": "#E8846A",
      "cream": "#F5E6C8",
      "lavender": "#A89EC4"
    },
    "text": {
      "primary": "#F5F5F5",
      "secondary": "#A3A3A3",
      "muted": "#737373",
      "inverse": "#141414"
    },
    "border": {
      "subtle": "rgba(255, 255, 255, 0.08)",
      "visible": "rgba(255, 255, 255, 0.15)",
      "active": "#B5CC6A"
    }
